#!/usr/bin/env bash
set -euo pipefail

################################################################################
# Setup Real World Rails
################################################################################
#
# OVERVIEW
# --------
# Initialize and download all submodules after first clone.
#
# USAGE
# -----
#   bin/setup              # Shallow clone, latest commit only (~10 GB)
#   bin/setup --full       # Full clone with complete git history (~29 GB)
#
# Existing users can switch to shallow clones to reclaim disk space:
#   bin/setup --reset
#
################################################################################

# Colors
green='\033[0;32m'
nc='\033[0m'

################################################################################
# Main Orchestration
################################################################################

main() {
  parse_options "$@"

  if [ "$RESET" = true ]; then
    reset_submodules
  fi

  init_submodules
  log "Setup complete! Explore the apps/ and engines/ directories."
  log "Run 'bin/update' anytime to pull the latest changes."
}

################################################################################
# Helper Functions
################################################################################

log() { echo -e "${green}==>${nc} ${1}"; }

parse_options() {
  FULL=false
  RESET=false

  for arg in "$@"; do
    case "$arg" in
      --full)  FULL=true ;;
      --reset) RESET=true ;;
      *)
        echo "Unknown option: $arg"
        echo "Usage: bin/setup [--full] [--reset]"
        exit 1
        ;;
    esac
  done
}

################################################################################
# Core Functions
################################################################################

reset_submodules() {
  log "Removing existing submodules to re-clone..."
  git submodule deinit --all --force
}

init_submodules() {
  if [ "$FULL" = true ]; then
    log "Initializing submodules with full history (~29 GB)..."
    log "This may take a while on first run"
    GIT_LFS_SKIP_SMUDGE=1 git submodule update --init --single-branch --jobs 4
  else
    log "Initializing submodules with shallow clone (latest commit only)..."
    log "Use --full to include complete git history"
    GIT_LFS_SKIP_SMUDGE=1 git submodule update --init --single-branch --depth 1 --jobs 4
  fi
}

################################################################################
# Script Execution
################################################################################

main "$@"
