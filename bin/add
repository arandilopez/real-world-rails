#!/usr/bin/env bash
set -e

if [ -z "$1" ]; then
  echo "Usage: bin/add <github-url> [type]"
  echo ""
  echo "  github-url  GitHub repo URL (e.g. https://github.com/user/repo)"
  echo "  type        'app' (default) or 'engine'"
  echo ""
  echo "Examples:"
  echo "  bin/add https://github.com/basecamp/kamal"
  echo "  bin/add https://github.com/ankane/blazer engine"
  exit 1
fi

url="$1"
type="${2:-app}"

# Parse owner/repo from URL
repo_path=$(echo "$url" | sed 's|.*github.com/||' | sed 's|\.git$||' | sed 's|/$||')
name=$(basename "$repo_path")

if [ "$type" = "engine" ]; then
  dest="engines/$name"
else
  dest="apps/$name"
fi

if [ -d "$dest" ]; then
  echo "Error: $dest already exists"
  exit 1
fi

# Get default branch
echo "Looking up default branch for $repo_path..."
default_branch=$(gh repo view "$repo_path" --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null)

if [ -z "$default_branch" ]; then
  echo "Error: Could not find repo $repo_path"
  exit 1
fi

echo "Adding $name ($default_branch branch) to $dest..."
GIT_LFS_SKIP_SMUDGE=1 git submodule add -b "$default_branch" "git@github.com:${repo_path}.git" "$dest"

echo ""
echo "Added $name to $dest"
echo ""
echo "Next steps:"
echo "  1. Add an entry to repos.md"
echo "  2. Commit and push"
